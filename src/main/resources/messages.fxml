<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" stylesheets="messages.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.Messages">

    <!-- Liste des discussions -->
    <ListView fx:id="discussionListView" layoutX="10.0" layoutY="60.0" prefHeight="344.0" prefWidth="200.0" />

    <!-- Zone de l'en-tête (barre rouge) -->
    <HBox alignment="CENTER_LEFT" layoutX="0.0" layoutY="0.0" prefHeight="50.0" prefWidth="800.0" spacing="10" style="-fx-background-color: #bb0b0b;">
        <ImageView fitHeight="30" fitWidth="30">
            <image>
                <Image url="@images/logn44.png" />
            </image>
        </ImageView>
        <Label alignment="CENTER" contentDisplay="CENTER" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Messages Formini" />
    </HBox>

    <!-- Zone des messages -->
    <ScrollPane fitToWidth="true" layoutX="230.0" layoutY="58.0" prefHeight="350.0" prefWidth="550.0">
        <content>
            <VBox fx:id="messagesBox" spacing="10.0">
                <padding>
                    <Insets bottom="10" left="10" right="10" top="10" />
                </padding>
            </VBox>
        </content>
    </ScrollPane>

    <!-- Zone des interactions avec l'utilisateur -->
    <VBox layoutX="230.0" layoutY="420.0" prefWidth="550.0" spacing="10.0" />

    <!-- Zone d'envoi de message -->
    <HBox layoutX="230.0" layoutY="480.0" prefWidth="550.0" spacing="10.0">
        <TextArea fx:id="messageTextArea" prefHeight="50.0" prefWidth="450.0" promptText="Écrire un message..." />
        <Button layoutX="689.0" onAction="#envoyerMessage" text="Envoyer" />
    </HBox>
     <!-- Bouton pour ajouter une nouvelle discussion -->
     <Button fx:id="addDiscussionBtn" layoutX="10.0" layoutY="455.0" prefWidth="200.0" text="Ajouter Discussion" />
     <!-- ComboBox pour sélectionner un utilisateur -->
     <ComboBox fx:id="userComboBox" layoutX="10.0" layoutY="420.0" prefWidth="200.0" />

</AnchorPane>
